# =============================================================================
# untitled build — environment
# -----------------------------------------------------------------------------
# Copy to `.env` for local dev and set the same vars in your host's build env
# (and in the GitHub Actions deploy, as repo "Variables" — NOT secrets, since
# the anon key is public by design).
#
# The contact form writes directly to Supabase from the browser using the
# PUBLIC anon key. Security is enforced by a Row-Level-Security policy that
# allows INSERT-only into the submissions table (see infra/supabase/schema.sql).
# The site therefore stays 100% static — no server, no token in the bundle.
#
# Astro only exposes vars prefixed with PUBLIC_ to client code.
# =============================================================================

PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
