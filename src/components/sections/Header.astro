---
import Container from '@components/primitives/Container.astro';
import Wordmark from '@components/primitives/Wordmark.astro';
import { site } from '@data/site';
---

<header class="relative z-30 pt-7 sm:pt-9">
  <Container class="flex items-end justify-between gap-6">
    <a
      href="#top"
      class="text-[clamp(1.25rem,1rem+1vw,1.55rem)] leading-none text-ink"
      aria-label={`${site.name} — home`}
    >
      <Wordmark />
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-8">
        {
          site.nav.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="font-sans text-nav tracking-tight text-link transition-opacity duration-200 hover:opacity-60"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </Container>
</header>
