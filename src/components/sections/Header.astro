---
/**
 * Page header — just the brand wordmark, aligned to the hero content column so
 * the logo sits directly above the headline (Figma x≈410). No nav.
 */
import Wordmark from '@components/primitives/Wordmark.astro';
import { site } from '@data/site';
---

<header class="relative z-30 pt-[clamp(1.25rem,2.4vw,1.5rem)]">
  <div class="mx-auto w-full max-w-[45.75rem] px-5 md:px-0">
    <a
      href="#top"
      aria-label={`${site.name} — home`}
      class="inline-block md:pl-[26px]"
    >
      <Wordmark class="text-[1.4rem]" />
    </a>
  </div>
</header>
