---
import Section from '@components/primitives/Section.astro';
import Container from '@components/primitives/Container.astro';
import SectionHeading from '@components/primitives/SectionHeading.astro';
import Button from '@components/primitives/Button.astro';
import Icon from '@components/primitives/Icon.astro';
import Reveal from '@components/primitives/Reveal.astro';
import { site } from '@data/site';

const { whyUs, cta } = site;
---

<Section id="why-us">
  <Container>
    <div class="flex flex-col gap-12 lg:flex-row lg:items-stretch lg:gap-10">
      {/* copy column — fixed-ish width so the display heading sits on ~2 lines */}
      <Reveal class="flex flex-col items-start lg:w-[42rem] lg:shrink-0">
        <SectionHeading
          eyebrow={whyUs.eyebrow}
          title={whyUs.title}
          lead={whyUs.body}
        />

        <ul class="mt-9 flex flex-wrap items-center gap-x-10 gap-y-4">
          {
            whyUs.features.map((feature) => (
              <li class="flex items-center gap-2">
                <Icon name={feature.icon} class="size-6 shrink-0 text-ink" />
                <span class="text-feature tracking-tight text-ink">
                  {feature.label}
                </span>
              </li>
            ))
          }
        </ul>

        <Button class="mt-10" href={cta.href} label={cta.label} />
      </Reveal>

      {/*
        Illustration placeholder. On desktop it fills the remaining width and
        bleeds to the right viewport edge (calc trick) with a squared right
        corner; on mobile it's a normal full-width block below the copy.
      */}
      <Reveal
        class="flex min-h-[18rem] items-center justify-center rounded-card border border-white bg-surface sm:min-h-[24rem] lg:min-h-0 lg:flex-1 lg:mr-[calc(50%-50vw)] lg:rounded-r-none"
      >
        <span class="font-mono text-[0.95rem] uppercase tracking-widest text-body opacity-40">
          {whyUs.illustrationCaption}
        </span>
      </Reveal>
    </div>
  </Container>
</Section>
