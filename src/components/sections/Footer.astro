---
/**
 * Footer — the oversized "untitled build" wordmark watermark (the Figma's
 * closing flourish) above a slim utility row. The wordmark is clipped by the
 * body's overflow so it can run edge-to-edge.
 */
import Container from '@components/primitives/Container.astro';
import Wordmark from '@components/primitives/Wordmark.astro';
import { site } from '@data/site';

const year = 2026;
---

<footer class="relative overflow-hidden pt-[clamp(1.5rem,3vw,2.5rem)]">
  {/* slim utility row */}
  <Container width="container" class="flex flex-col items-center justify-between gap-3 sm:flex-row">
    <a href="#top" data-cursor="link" aria-label={`${site.name} — top`} class="inline-block">
      <Wordmark class="text-[1.1rem]" />
    </a>
    <div class="flex items-center gap-6">
      <a
        href={`mailto:${site.contactEmail}`}
        class="font-sans text-[0.9rem] font-medium tracking-tight text-body transition-colors hover:text-brand"
        data-cursor="link"
      >
        Contact
      </a>
      <p class="font-sans text-[0.85rem] tracking-tight text-body">© {year} {site.name}</p>
    </div>
  </Container>

  {/* oversized watermark (Figma: #DCDCDC) */}
  <div class="pointer-events-none mt-[clamp(1.25rem,2.5vw,2rem)] flex justify-center select-none" aria-hidden="true">
    <Wordmark mono class="whitespace-nowrap text-center text-[clamp(2.75rem,13.5vw,11rem)] leading-none text-wordmark" />
  </div>
</footer>
