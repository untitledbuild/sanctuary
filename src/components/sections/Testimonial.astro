---
/**
 * Testimonial band — a measured "blueprint" band (top/bottom hairlines + vertical
 * tick marks) with the outlined double-quote glyph on the left, the centred
 * serif pull-quote, the star rating above, and the author byline on the right.
 * Values lifted from Figma (band x108–1390 / y554–696). Desktop uses the precise
 * absolute composition; under lg it stacks centred.
 */
import Avatar from '@components/primitives/Avatar.astro';
import Icon from '@components/primitives/Icon.astro';
import { site, type Testimonial } from '@data/site';

const t: Testimonial = site.testimonial;

// Exact quote-mark silhouette path (40×72), drawn as an outline; two marks.
const QUOTE_PATH =
  'M14.55 71.7L25.725 71.7C33.9 71.7 40.275 65.325 40.275 57.15L40.275 45.975C40.275 37.8 33.9 31.425 25.725 31.425L11.4 31.425C12 17.85 15.15 15.825 24.225 10.5C26.925 8.925 27.75 5.475 26.175 2.775C25.125 0.975 23.25 0 21.3 0C20.325 0 19.35 0.225 18.45 0.75C5.025 8.7 0 13.875 0 36.975L0 57C0 65.175 6.525 71.7 14.55 71.7Z';

// Vertical tick marks: % of band width (1282), Figma x − 108.
const ticks = [17.6, 21.5, 28.9, 71.1, 78.6, 84.0];
---

<section aria-label="What clients say" class="relative pt-[clamp(1.25rem,2.5vw,2rem)] pb-[clamp(1rem,2vw,1.75rem)]">
  <div class="mx-auto w-full max-w-[80.125rem] px-[var(--container-pad)]">
    {/* stars (above the band) */}
    <div class="mb-[0.875rem] flex justify-center gap-0" aria-label={`${t.rating} out of 5 stars`} data-reveal>
      {Array.from({ length: t.rating }).map(() => (
        <Icon name="star" size={22} class="text-[#D9D9D9]" />
      ))}
    </div>

    {/* ---- Desktop: measured band ---- */}
    <div class="relative hidden h-[8.875rem] border-y border-hairline lg:block">
      {ticks.map((x) => (
        <span
          class="absolute top-[-0.875rem] h-[10.5rem] border-l border-hairline"
          style={`left:${x}%`}
        ></span>
      ))}

      {/* outlined double-quote, left */}
      <svg
        class="absolute left-[5.3%] top-1/2 h-[6.625rem] w-[6.625rem] -translate-y-1/2 text-black/40"
        viewBox="0 0 106 106"
        fill="none"
        stroke="currentColor"
        stroke-width="1"
        aria-hidden="true"
      >
        <path d={QUOTE_PATH} transform="translate(10 17)"></path>
        <path d={QUOTE_PATH} transform="translate(56 17)"></path>
      </svg>

      {/* centred quote — no data-reveal: it relies on a centering transform
          that the reveal animation (which animates `y`) would overwrite. */}
      <blockquote
        class="absolute left-1/2 top-1/2 w-[36.25rem] max-w-[80%] -translate-x-1/2 -translate-y-1/2 text-center font-serif text-[2.5rem] italic leading-[1.2] tracking-serif text-navy"
      >
        {t.quote}
      </blockquote>

      {/* byline, right (same transform-centering caveat → no data-reveal) */}
      <div class="absolute right-[3.5%] top-1/2 flex -translate-y-1/2 items-center gap-[0.857rem]">
        <Avatar src={t.avatar} alt={t.author} size={52} />
        <span class="flex w-[9.7rem] flex-col">
          <span class="font-sans text-[1.3625rem] leading-[1.44] tracking-tight text-ink">{t.author}</span>
          <span class="text-center font-serif text-[1.03125rem] italic tracking-serif text-navy">{t.role}</span>
        </span>
      </div>
    </div>

    {/* ---- Mobile: centred stack ---- */}
    <div class="flex flex-col items-center gap-6 lg:hidden">
      <svg class="h-16 w-16 text-black/30" viewBox="0 0 106 106" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d={QUOTE_PATH} transform="translate(10 17)"></path>
        <path d={QUOTE_PATH} transform="translate(56 17)"></path>
      </svg>
      <blockquote class="max-w-[34rem] text-center font-serif text-[clamp(1.6rem,6vw,2.25rem)] italic leading-[1.2] tracking-serif text-navy" data-reveal>
        {t.quote}
      </blockquote>
      <div class="flex items-center gap-3" data-reveal>
        <Avatar src={t.avatar} alt={t.author} size={48} />
        <span class="flex flex-col">
          <span class="font-sans text-[1.25rem] leading-[1.3] tracking-tight text-ink">{t.author}</span>
          <span class="font-serif text-[1rem] italic tracking-serif text-navy">{t.role}</span>
        </span>
      </div>
    </div>
  </div>
</section>
