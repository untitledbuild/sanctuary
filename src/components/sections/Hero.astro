---
/**
 * Hero — headline + lead on the left inside a dashed "blueprint" frame (dotted
 * fill + diagonal hatch strip near the bottom), with the contact-form card on
 * the right overlapping the frame and poking above/below it.
 *
 * Geometry is lifted from Figma (732px frame centred on the canvas), authored in
 * rem (px ÷ 16) so it scales with the fluid root. Origin = the form's top edge.
 * Desktop only; mobile stacks with no frame.
 */
import ContactForm from './ContactForm.astro';
import { site } from '@data/site';

const { hero } = site;

const dots =
  'background-image:radial-gradient(rgba(0,0,0,0.16) 0.07rem, transparent 0.106rem);background-size:1.5rem 1.5rem';
const hatch =
  'background-image:repeating-linear-gradient(45deg, rgba(0,0,0,0.16) 0, rgba(0,0,0,0.16) 0.0625rem, transparent 0.0625rem, transparent 0.844rem)';
---

<section id="top" class="relative pt-[clamp(1.5rem,3.5vw,2.5rem)]">
  <div class="relative mx-auto w-full max-w-[45.75rem] px-5 md:px-0">
    {/* ---- Decoration (desktop only), origin = form top ---- */}
    <div class="pointer-events-none absolute inset-0 hidden md:block" aria-hidden="true">
      {/* tall vertical dashed lines at the frame edges */}
      <span class="dashed-v absolute left-0 top-[-2.9375rem] h-[31.375rem]"></span>
      <span class="dashed-v absolute right-0 top-[-2.9375rem] h-[31.375rem]"></span>
      {/* top edge */}
      <span class="dashed-h absolute left-[-1rem] right-[-1rem] top-[1.6875rem]"></span>
      {/* dotted fill (732×262) */}
      <div class="absolute inset-x-0 top-[2.4375rem] h-[16.375rem]" style={dots}></div>
      {/* diagonal hatch strip + the dashed lines bracketing it */}
      <span class="dashed-h absolute left-[-1rem] right-[-1rem] top-[18.8125rem]"></span>
      <div class="absolute inset-x-0 top-[18.8125rem] h-[1.25rem]" style={hatch}></div>
      <span class="dashed-h absolute left-[-1rem] right-[-1rem] top-[20.0625rem]"></span>
      <span class="dashed-h absolute left-[-1rem] right-[-1rem] top-[21.125rem]"></span>
    </div>

    {/* ---- Content ---- */}
    <div class="relative grid grid-cols-1 gap-y-9 md:grid-cols-[1fr_19.3125rem] md:gap-x-[2.5625rem] md:items-start">
      <div class="md:pl-[1.625rem] md:pt-[3.9375rem]">
        <h1
          class="font-sans text-hero font-medium leading-[var(--text-hero--line-height)] tracking-tight text-heading"
          data-reveal
        >
          {hero.title.split('\n').map((line) => <span class="block whitespace-nowrap">{line}</span>)}
        </h1>
        <p
          class="mt-3.5 max-w-[16.1rem] font-sans text-lead font-medium leading-[var(--text-lead--line-height)] tracking-tight text-body"
          data-reveal
          data-reveal-delay="0.08"
        >
          {hero.subtitle}
        </p>
      </div>

      <div data-reveal data-reveal-delay="0.16">
        <ContactForm />
      </div>
    </div>
  </div>
</section>
