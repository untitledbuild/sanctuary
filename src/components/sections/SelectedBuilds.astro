---
import Section from '@components/primitives/Section.astro';
import Container from '@components/primitives/Container.astro';
import SectionHeading from '@components/primitives/SectionHeading.astro';
import Reveal from '@components/primitives/Reveal.astro';
import { site } from '@data/site';

const { selectedBuilds } = site;
---

<Section id="projects">
  <Container>
    <SectionHeading
      eyebrow={selectedBuilds.eyebrow}
      title={selectedBuilds.title}
      titleClass="text-wrap"
    />

    <div class="mt-[clamp(2.5rem,5vw,4rem)] grid grid-cols-1 gap-8 sm:grid-cols-2">
      {
        /* Placeholder surfaces today; drop in image/title (and wrap in an <a>
           via project.href) as real work ships — see src/data/site.ts. */
        selectedBuilds.projects.map((project) => (
          <Reveal
            class="group relative block aspect-[488/475] overflow-hidden rounded-card border border-white bg-surface transition-transform duration-300 ease-out hover:-translate-y-1"
          >
            {project.image && (
              <img
                src={project.image}
                alt={project.title ?? ''}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            )}
            {project.title && (
              <span class="absolute inset-x-0 bottom-0 p-6 text-feature tracking-tight text-ink">
                {project.title}
              </span>
            )}
          </Reveal>
        ))
      }
    </div>
  </Container>
</Section>
