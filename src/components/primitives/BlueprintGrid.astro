---
/**
 * Decorative dashed "blueprint" construction grid — the engineering motif that
 * runs behind the whole page in the Figma. An inline SVG <pattern> keeps the
 * dashes crisp and tiles to any viewport. Purely decorative (aria-hidden).
 *
 * `variant`:
 *   - 'lines'   → full dashed grid (default), used as the page backdrop
 *   - 'columns' → vertical dashed rules only (section dividers)
 * Made parallax-capable via `data-parallax` so the backdrop drifts faster than
 * the foreground (depth), unless reduced-motion.
 */
interface Props {
  class?: string;
  gap?: number;
  tone?: 'soft' | 'line' | 'guide';
  opacity?: number;
  variant?: 'lines' | 'columns';
  parallax?: number;
}
const {
  class: className = '',
  gap = 73,
  tone = 'guide',
  opacity = 1,
  variant = 'lines',
  parallax,
} = Astro.props;

const pid = `bp-${crypto.randomUUID().slice(0, 8)}`;
const stroke =
  tone === 'line'
    ? 'var(--color-line)'
    : tone === 'soft'
      ? 'var(--color-line-soft)'
      : 'var(--color-line-guide)';
const d = variant === 'columns' ? `M${gap} 0 V${gap}` : `M${gap} 0 V${gap} M0 ${gap} H${gap}`;
---

<svg
  class:list={['pointer-events-none absolute inset-0 -z-10 h-full w-full', className]}
  style={`opacity:${opacity}`}
  aria-hidden="true"
  preserveAspectRatio="none"
  data-parallax={parallax}
>
  <defs>
    <pattern id={pid} width={gap} height={gap} patternUnits="userSpaceOnUse">
      <path d={d} fill="none" stroke={stroke} stroke-width="1" stroke-dasharray="6 7"></path>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill={`url(#${pid})`}></rect>
</svg>
