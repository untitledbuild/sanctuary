---
/**
 * Round avatar — a real image when provided, otherwise the Untitled-UI grey
 * placeholder with a user glyph (matches the Figma "Avatar" component).
 */
import Icon from './Icon.astro';

interface Props {
  src?: string;
  alt?: string;
  size?: number;
  ring?: boolean;        /* white ring used in the overlapping avatar group */
  class?: string;
}
const { src, alt = '', size = 52, ring = false, class: className = '' } =
  Astro.props;
---

<span
  class:list={[
    'inline-grid place-items-center overflow-hidden rounded-full',
    'border border-gray-200 bg-gray-100 text-gray-400',
    ring && 'ring-2 ring-white',
    className,
  ]}
  style={`width:${size}px;height:${size}px`}
>
  {
    src ? (
      <img src={src} alt={alt} width={size} height={size} class="h-full w-full object-cover" loading="lazy" />
    ) : (
      <Icon name="user" size={Math.round(size * 0.5)} stroke={2} />
    )
  }
</span>
