---
/**
 * Semantic <section> carrying the vertical rhythm (--section-y). `relative` by
 * default so decorative layers (blueprint grid, bleeds) can anchor to it.
 */
interface Props {
  id?: string;
  class?: string;
  /** Toggle the standard vertical padding (off for full-bleed sections). */
  spaced?: boolean;
  'aria-label'?: string;
}
const {
  id,
  class: className = '',
  spaced = true,
  'aria-label': ariaLabel,
} = Astro.props;
---

<section
  id={id}
  aria-label={ariaLabel}
  class:list={['relative', spaced && 'py-[var(--section-y)]', className]}
>
  <slot />
</section>
