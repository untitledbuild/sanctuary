      <rect x="14" y="14" width="7" height="7" rx="1" />
      <rect x="3" y="14" width="7" height="7" rx="1" />
    </>
  )}
  {name === 'git-branch' && (
    <>
      <path d="M6 3v12" />
      <circle cx="18" cy="6" r="3" />
      <circle cx="6" cy="18" r="3" />
      <path d="M18 9a9 9 0 0 1-9 9" />
    </>
  )}
  {name === 'star' && (
    <path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
  )}
  {name === 'quote' && (
    <path d="M7.5 7C5.5 8 4.2 9.9 4.2 12.3c0 .15.01.3.02.45A3.2 3.2 0 0 0 6.8 18a3.2 3.2 0 0 0 .3-6.39c.16-1.3.92-2.4 2.07-3l-1.67-1.6Zm9 0c-2 1-3.3 2.9-3.3 5.3 0 .15.01.3.02.45A3.2 3.2 0 0 0 15.8 18a3.2 3.2 0 0 0 .3-6.39c.16-1.3.92-2.4 2.07-3L16.5 7Z" />
  )}
  {name === 'linkedin' && (
    <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 9.67H5.67V18h2.67V9.67ZM7 6a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm11.33 6.87c0-2.3-1.23-3.37-2.87-3.37-1.32 0-1.91.73-2.24 1.24V9.67h-2.67V18h2.67v-4.4c0-.24.02-.47.09-.64.19-.47.62-.96 1.34-.96.95 0 1.32.72 1.32 1.77V18h2.66l.01-5.13Z" />
  )}
</svg>
