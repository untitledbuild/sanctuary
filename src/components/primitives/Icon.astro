---
/**
 * Inline UI icon set — recreates the Untitled UI line glyphs referenced in the
 * Figma (toolbar, form, feature rows, whiteboard chrome, commit card). All are
 * stroke icons on a 24×24 grid inheriting `currentColor`; size via the `size`
 * prop (defaults to the Figma 24px box) or a text/size class on the parent.
 * Decorative by default (aria-hidden) unless given a `title`.
 */
import type { IconName } from './icon-names';

interface Props {
  name: IconName;
  class?: string;
  /** px size; defaults to 24 (the Figma icon box). */
  size?: number;
  /** Stroke width (Figma uses ~1.66 at 20px / 2 at 24px). */
  stroke?: number;
  title?: string;
}

const { name, class: className = '', size = 24, stroke = 2, title } = Astro.props;
const solid = name === 'star' || name === 'quote' || name === 'linkedin';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={solid ? 'currentColor' : 'none'}
  stroke={solid ? 'none' : 'currentColor'}
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  focusable="false"
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
>
  {name === 'users' && (
    <>
      <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
      <circle cx="9" cy="7" r="4" />
    </>
  )}
  {name === 'dataflow' && (
    <>
      <rect x="14.5" y="2.5" width="7" height="6" rx="1.5" />
      <rect x="2.5" y="15.5" width="7" height="6" rx="1.5" />
      <rect x="14.5" y="15.5" width="7" height="6" rx="1.5" />
      <path d="M18 8.5v2a3 3 0 0 1-3 3H9a3 3 0 0 0-3 3v1" />
      <path d="M18 13.5v2" />
    </>
  )}
  {name === 'user' && (
    <>
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </>
  )}
  {name === 'plus' && <path d="M12 5v14M5 12h14" />}
  {name === 'chevron-down' && <path d="m6 9 6 6 6-6" />}
  {name === 'arrow-right' && <path d="M5 12h14M13 6l6 6-6 6" />}
  {name === 'check' && <path d="M20 6 9 17l-5-5" />}
  {name === 'edit' && (
    <>
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
      <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5Z" />
    </>
  )}
  {name === 'flip-backward' && (
    <>
      <path d="M3 7v6h6" />
      <path d="M3 13a9 9 0 1 0 3-7.7L3 8" />
    </>
  )}
  {name === 'flip-forward' && (
    <>
      <path d="M21 7v6h-6" />
      <path d="M21 13a9 9 0 1 1-3-7.7L21 8" />
    </>
  )}
  {name === 'share' && (
    <>
      <path d="M12 2v13" />
      <path d="m8 6 4-4 4 4" />
      <path d="M20 12v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7" />
    </>
  )}
  {name === 'settings' && (
    <>
      <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z" />
    </>
  )}
  {name === 'search' && (
    <>
      <circle cx="11" cy="11" r="7" />
      <path d="m21 21-4.3-4.3" />
    </>
  )}
  {name === 'bell' && (
    <>
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" />
