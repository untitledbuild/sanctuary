      <path d="M4 12h16" />
    </>
  )}
  {name === 'keyboard' && (
    <>
      <rect x="2" y="6" width="20" height="12" rx="2" />
      <path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M8 14h8" />
    </>
  )}
  {name === 'cube' && (
    <>
      <path d="M21 7.5 12 3 3 7.5v9L12 21l9-4.5v-9Z" />
      <path d="M3 7.5 12 12l9-4.5M12 12v9" />
    </>
  )}
  {name === 'arrow-up-right' && <path d="M7 17 17 7M7 7h10v10" />}
  {name === 'eraser' && (
    <>
      <path d="M19 20H8.5L3 14.5a1.5 1.5 0 0 1 0-2.1l8.4-8.4a1.5 1.5 0 0 1 2.1 0l6 6a1.5 1.5 0 0 1 0 2.1L13 20" />
      <path d="m8.5 14 6-6" />
    </>
  )}
  {name === 'pencil' && (
    <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" />
  )}
  {name === 'message' && (
    <>
      <path d="M21 11.5a8.38 8.38 0 0 1-9 8.4 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 17 .5Z" />
