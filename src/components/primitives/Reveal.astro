---
/**
 * Marks an element for scroll-reveal. The animation itself is driven by
 * src/scripts/motion.ts (GSAP + ScrollTrigger.batch), so this stays a thin,
 * dependency-free wrapper. Without JS / with reduced-motion the element is
 * simply visible (see global.css) — progressive enhancement.
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  class?: string;
  /** Travel distance in px (default 24, set in motion.ts). */
  y?: number;
  /** Extra delay in seconds for deliberate sequencing (e.g. hero). */
  delay?: number;
}
const { as: Tag = 'div', class: className = '', y, delay } = Astro.props;
---

<Tag
  class={className}
  data-reveal
  data-reveal-y={y}
  data-reveal-delay={delay}
>
  <slot />
</Tag>
