      <path d="M8 7c-1.5 0-2.5 1.2-2.5 4 0 3.5.8 6.5 2 6.5.6 0 .9-.5 1-1.3M14.5 6.8c1.8 0 2.5 1.6 2.5 4.2 0 1.6-.3 2.7-.9 3.2M10.5 7c.8-.4 2.4-.5 3.5 0M11.7 8v6.5" stroke="#fff" stroke-width="1.2" fill="none" stroke-linecap="round" />
    </>
  )}
  {name === 'aws' && (
    <>
      <path d="M6 10.5c0 .4.05.7.13.96.09.25.2.52.35.81.05.08.07.16.07.23 0 .1-.06.2-.2.3l-.64.43a.5.5 0 0 1-.27.09c-.1 0-.2-.05-.3-.14a3 3 0 0 1-.36-.47 8 8 0 0 1-.31-.59c-.78.92-1.76 1.38-2.94 1.38-.84 0-1.5-.24-2-.72-.49-.48-.74-1.12-.74-1.92 0-.85.3-1.54.91-2.06.6-.52 1.41-.78 2.43-.78.34 0 .68.03 1.05.08.36.05.74.13 1.13.22v-.71c0-.76-.16-1.29-.47-1.6-.32-.3-.86-.45-1.63-.45-.35 0-.71.04-1.08.13-.37.08-.73.19-1.08.32a2.9 2.9 0 0 1-.35.13.6.6 0 0 1-.16.03c-.14 0-.21-.1-.21-.31v-.49c0-.16.02-.28.07-.35a.74.74 0 0 1 .28-.21c.35-.18.77-.33 1.26-.45A6 6 0 0 1 3.99 4c1.16 0 2.01.26 2.56.79.54.52.81 1.32.81 2.4v3.31Z" fill="#FF9900" transform="translate(2.5 1.5) scale(0.85)" />
