    </>
  )}
  {name === 'node' && (
    <>
      <path d="m12 2 8.66 5v10L12 22l-8.66-5V7L12 2Z" fill="#5FA04E" />
      <path d="M12 7.5c-2.2 0-3.4.9-3.4 2.4 0 1.6 1.1 2 2.9 2.3 2.1.3 2.3.5 2.3 1 0 .5-.4.8-1.5.8-1 0-1.6-.3-1.9-.9h-1.8c.2 1.5 1.4 2.3 3.7 2.3 2.3 0 3.5-.9 3.5-2.5 0-1.6-1.1-2-3-2.3-2-.3-2.2-.5-2.2-1 0-.4.4-.7 1.4-.7.9 0 1.4.3 1.6.9h1.8c-.2-1.4-1.3-2.3-3.5-2.3Z" fill="#fff" />
    </>
  )}
  {name === 'tailwind' && (
    <path d="M12 6c-2.7 0-4.3 1.3-5 4 1-1.3 2.2-1.8 3.5-1.5.74.18 1.27.72 1.86 1.32C13.32 10.79 14.45 12 17 12c2.7 0 4.3-1.3 5-4-1 1.3-2.2 1.8-3.5 1.5-.74-.18-1.27-.72-1.86-1.32C15.68 7.21 14.55 6 12 6Zm-5 6c-2.7 0-4.3 1.3-5 4 1-1.3 2.2-1.8 3.5-1.5.74.18 1.27.72 1.86 1.32C8.32 16.79 9.45 18 12 18c2.7 0 4.3-1.3 5-4-1 1.3-2.2 1.8-3.5 1.5-.74-.18-1.27-.72-1.86-1.32C10.68 13.21 9.55 12 7 12Z" fill="#38BDF8" />
  )}
  {name === 'postgresql' && (
