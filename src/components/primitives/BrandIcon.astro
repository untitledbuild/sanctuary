    </>
  )}
  {name === 'typescript' && (
    <>
      <rect x="2" y="2" width="20" height="20" rx="2.5" fill="#3178C6" />
      <path d="M12.8 12.2h4.4M15 12.2v6" stroke="#fff" stroke-width="1.6" stroke-linecap="round" />
