    </>
  )}
  {name === 'stripe' && (
    <>
      <rect x="2" y="2" width="20" height="20" rx="4" fill="#635BFF" />
      <path d="M11.4 9.4c0-.5.43-.7 1.06-.7.97 0 2.2.3 3.17.83V6.6A8 8 0 0 0 12.46 6c-2.13 0-3.55 1.13-3.55 3.02 0 2.94 3.97 2.47 3.97 3.74 0 .56-.49.74-1.16.74-1.06 0-2.45-.44-3.5-1.03v2.8c1.17.5 2.35.72 3.5.72 2.18 0 3.68-1.1 3.68-3.02-.01-3.17-3.99-2.6-3.99-3.81Z" fill="#fff" />
