---
/**
 * Brand / product logos — the app-dock tiles, the tech-stack strip, GitHub and
 * our own `ub` monogram. Each is a self-contained coloured SVG on a 24×24 grid
 * (sized via the `size` prop). Iconic marks (Chrome, Figma, GitLab, Spotify)
 * keep their multi-colour identity; the rest use their official brand hue.
 *
 * Decorative (aria-hidden) — every tile/pill carries its own visible/labelled
 * text or an aria-label on the wrapper.
 */
import type { BrandName, TechName } from '@data/site';

interface Props {
  name: BrandName | TechName;
  size?: number;
  class?: string;
}
const { name, size = 24, class: className = '' } = Astro.props;
const box = `0 0 24 24`;
---

<svg class={className} width={size} height={size} viewBox={box} fill="none" aria-hidden="true" focusable="false">
  {/* ---- App dock --------------------------------------------------- */}
  {name === 'spotify' && (
    <>
      <circle cx="12" cy="12" r="11" fill="#1ED760" />
      <path d="M6.8 10.4c3.4-1 7.6-.8 10.6 1M7.4 13.6c2.8-.8 6-.6 8.4.9M8 16.5c2.2-.6 4.6-.4 6.5.8" stroke="#fff" stroke-width="1.6" stroke-linecap="round" />
    </>
  )}
  {name === 'chrome' && (
    <>
      <circle cx="12" cy="12" r="11" fill="#fff" />
      <path d="M12 1a11 11 0 0 1 9.53 5.5H12a5.5 5.5 0 0 0-4.76 8.25L3.2 7.78A11 11 0 0 1 12 1Z" fill="#EA4335" />
      <path d="M21.53 6.5A11 11 0 0 1 12 23l4.76-8.25A5.5 5.5 0 0 0 12 6.5h9.53Z" fill="#FBBC05" />
      <path d="M12 23A11 11 0 0 1 3.2 7.78l4.04 6.97A5.5 5.5 0 0 0 12 17.5L12 23Z" fill="#34A853" />
      <circle cx="12" cy="12" r="4" fill="#fff" />
      <circle cx="12" cy="12" r="3.2" fill="#4285F4" />
    </>
  )}
  {name === 'gitlab' && (
    <>
      <path d="m12 22 3.2-9.8H8.8L12 22Z" fill="#E24329" />
      <path d="M12 22 8.8 12.2H4.3L12 22Z" fill="#FC6D26" />
      <path d="M4.3 12.2 3.3 15.3a.7.7 0 0 0 .25.78L12 22 4.3 12.2Z" fill="#FCA326" />
      <path d="M4.3 12.2h4.5L6.86 6.2a.35.35 0 0 0-.67 0L4.3 12.2Z" fill="#E24329" />
      <path d="m12 22 3.2-9.8h4.5L12 22Z" fill="#FC6D26" />
      <path d="m19.7 12.2 1 3.1a.7.7 0 0 1-.25.78L12 22l7.7-9.8Z" fill="#FCA326" />
      <path d="M19.7 12.2h-4.5l1.94-6a.35.35 0 0 1 .67 0l1.89 6Z" fill="#E24329" />
    </>
  )}
  {name === 'notion' && (
    <>
      <rect x="2" y="2" width="20" height="20" rx="3" fill="#fff" stroke="#000" stroke-width="1.2" />
      <path d="M8 8.2v7.6M8 8.2l8 7.6M16 8v7.8" stroke="#000" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
    </>
  )}
  {name === 'figma' && (
    <>
      <path d="M9 2h3v6.67H9A3.33 3.33 0 0 1 9 2Z" fill="#F24E1E" />
      <path d="M12 2h3a3.33 3.33 0 0 1 0 6.67h-3V2Z" fill="#FF7262" />
      <path d="M9 8.67h3v6.66H9a3.33 3.33 0 0 1 0-6.66Z" fill="#A259FF" />
