---
/**
 * Mobile-app frame (Figma: rounded #F7F7F7 panel with notch pill + swipe bar).
 * Proportions are percentage-based off a fixed aspect ratio, so it scales
 * cleanly at any width. Decorative.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    'relative h-full w-full overflow-hidden rounded-card border border-white bg-surface',
    className,
  ]}
  aria-hidden="true"
>
  {/* status / notch pill */}
  <div class="absolute left-1/2 top-[3.1%] h-[3.4%] w-[31%] -translate-x-1/2 rounded-full bg-[#dddddd]"></div>

  {/* faint app content placeholder */}
  <div class="absolute inset-x-[7%] top-[12%] bottom-[10%] flex flex-col gap-[4%]">
    <div class="h-[34%] rounded-block bg-block"></div>
    <div class="h-[16%] rounded-block bg-block/70"></div>
    <div class="flex-1 rounded-block bg-gradient-to-b from-block-soft to-transparent"></div>
  </div>

  {/* home swipe bar */}
  <div class="absolute bottom-[2.3%] left-1/2 h-[1.3%] w-[24%] -translate-x-1/2 rounded-full bg-black/[0.08]"></div>
</div>
