---
/**
 * Web-app frame (Figma: rounded #F7F7F7 window with traffic-light dots, a
 * centred address pill, a share action, a glass segmented control, and stacked
 * content blocks).
 *
 * The frame is a CSS container (`@container`) and every inner detail is sized in
 * `cqw` (1% of the frame's width), so chrome + text + icons scale in lock-step
 * with the mockup at any viewport. Decorative.
 */
import Icon from '@components/primitives/Icon.astro';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class:list={[
    '@container relative h-full w-full overflow-hidden rounded-browser bg-surface',
    className,
  ]}
  aria-hidden="true"
>
  {/* traffic-light dots */}
  <div class="absolute left-[3.4%] top-[3.2%] flex items-center gap-[1.1cqw]">
    <span class="block aspect-square w-[1.7cqw] rounded-full bg-[#d9d9d9]"></span>
    <span class="block aspect-square w-[1.7cqw] rounded-full bg-[#d9d9d9]"></span>
    <span class="block aspect-square w-[1.7cqw] rounded-full bg-[#d9d9d9]"></span>
  </div>

  {/* address / search pill */}
  <div
    class="absolute left-1/2 top-[1.8%] flex w-[36cqw] -translate-x-1/2 items-center gap-[1.3cqw] rounded-full bg-white px-[1.6cqw] py-[1cqw]"
  >
    <Icon name="search" class="w-[1.8cqw] shrink-0 text-[#cecece]" />
    <span class="truncate font-sans text-[1.25cqw] font-medium tracking-[-0.01em] text-[#a3a3a3]">
      https://www.XYZ.ai
    </span>
  </div>

  {/* share action */}
  <Icon name="share" class="absolute right-[5.5%] top-[3%] w-[2.1cqw] text-[#a8a8a8]" />

  {/* glass segmented control */}
  <div
    class="absolute left-1/2 top-[13.5%] flex w-[64cqw] -translate-x-1/2 items-center gap-[0.7cqw] rounded-full border border-[rgba(117,117,117,0.12)] bg-white/40 p-[0.45cqw] shadow-[0_0.35cqw_0.35cqw_rgba(0,0,0,0.04)] backdrop-blur-md"
  >
    <span class="h-[3.6cqw] w-[16cqw] rounded-full bg-[#f4f5f6] shadow-[inset_0_0_0_1px_rgba(0,0,0,0.02)]"></span>
    <span class="h-[3.6cqw] flex-1 rounded-full bg-[#f4f5f6]"></span>
    <span class="h-[3.6cqw] flex-1 rounded-full bg-[#f4f5f6]"></span>
  </div>

  {/* content blocks */}
  <div class="absolute inset-x-[7.5%] top-[23%] bottom-[7%] flex flex-col gap-[3.5%]">
    <div class="flex-[1.3] rounded-block bg-block"></div>
    <div class="flex h-[18%] gap-[4.5%]">
      <div class="w-[28%] rounded-block bg-block"></div>
      <div class="w-[28%] rounded-block bg-block"></div>
    </div>
    <div class="flex-[1.3] rounded-block bg-gradient-to-b from-block-soft to-transparent"></div>
  </div>
</div>
