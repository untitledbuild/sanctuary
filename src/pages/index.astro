---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/sections/Header.astro';
import Hero from '@components/sections/Hero.astro';
import Testimonial from '@components/sections/Testimonial.astro';
import AppDock from '@components/sections/AppDock.astro';
import Whiteboard from '@components/sections/Whiteboard.astro';
import People from '@components/sections/People.astro';
import TechLogos from '@components/sections/TechLogos.astro';
import Work from '@components/sections/Work.astro';
import CallToAction from '@components/sections/CallToAction.astro';
import Footer from '@components/sections/Footer.astro';
import GridField from '@components/primitives/GridField.astro';
---

<BaseLayout>
  <Header />
  <main>
    {/* First screenful: hero + testimonial sit together, centred in the
        viewport (minus header), so the app dock is revealed on scroll. */}
    <div class="flex min-h-[calc(100svh-3.5rem)] flex-col justify-center">
      <Hero />
      <Testimonial />
    </div>
    <AppDock />
    <Whiteboard />
    <People />
    <TechLogos />
    <Work />
  </main>
  {/* Closing band — one continuous dashed grid behind the CTA card + footer. */}
  <div class="relative isolate overflow-hidden">
    <GridField mask="vertical" />
    <CallToAction />
    <Footer />
  </div>
</BaseLayout>
