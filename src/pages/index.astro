---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/sections/Header.astro';
import Hero from '@components/sections/Hero.astro';
import Process from '@components/sections/Process.astro';
import WhyUs from '@components/sections/WhyUs.astro';
import Testimonial from '@components/sections/Testimonial.astro';
import SelectedBuilds from '@components/sections/SelectedBuilds.astro';
import FoundersNote from '@components/sections/FoundersNote.astro';
import CallToAction from '@components/sections/CallToAction.astro';
import Footer from '@components/sections/Footer.astro';
---

<BaseLayout>
